{
	"name": "@infineon/infineon-design-system-react",
	"version": "39.30.0",
	"description": "React wrapper for Infineon Design System Web Components",
	"keywords": [
		"infineon",
		"design-system",
		"react",
		"web-components",
		"ui-components"
	],
	"homepage": "https://infineon.github.io/infineon-design-system-stencil/",
	"bugs": {
		"url": "https://github.com/Infineon/infineon-design-system-stencil/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Infineon/infineon-design-system-stencil.git",
		"directory": "packages/wrapper-react"
	},
	"author": "Infineon Technologies AG",
	"license": "MIT",
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/types/index.d.ts",
	"scripts": {
		"build": "wireit",
		"tsc": "tsc -p . --outDir ./dist",
		"dev": "wireit"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@infineon/infineon-design-system-stencil": "workspace:*",
		"@stencil/react-output-target": "^1.2.0"
	},
	"devDependencies": {
		"@types/react": "^19.2.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"typescript": "5.9.3"
	},
	"wireit": {
		"prebuild": {
			"command": "cpy \"../components/build-wrapper/react/lib/components/stencil-generated/**\" lib/components/stencil-generated --parents",
			"dependencies": [
				"../components:build"
			],
			"files": [
				"../components/build-wrapper/react/lib/components/stencil-generated/**"
			],
			"output": [
				"lib/components/stencil-generated/**"
			]
		},
		"build": {
			"command": "tsc -p .",
			"dependencies": [
				"prebuild"
			],
			"files": [
				"lib/**",
				"tsconfig.json",
				"package.json"
			],
			"output": [
				"dist/**"
			]
		},
		"dev": {
			"command": "tsc -p . --watch --preserveWatchOutput --outDir ./dist",
			"service": {
				"readyWhen": {
					"lineMatches": "Watching for file changes"
				}
			},
			"dependencies": [
				{
					"script": "../components:dev:react",
					"cascade": false
				}
			]
		}
	}
}
