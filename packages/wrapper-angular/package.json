{
	"name": "@infineon/infineon-design-system-angular",
	"version": "39.31.0",
	"description": "Angular wrapper for Infineon Design System Web Components",
	"keywords": [
		"infineon",
		"design-system",
		"angular",
		"web-components",
		"ui-components"
	],
	"homepage": "https://infineon.github.io/infineon-design-system-stencil/",
	"bugs": {
		"url": "https://github.com/Infineon/infineon-design-system-stencil/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Infineon/infineon-design-system-stencil.git",
		"directory": "packages/wrapper-angular"
	},
	"author": "Infineon Technologies AG",
	"license": "MIT",
	"scripts": {
		"build": "wireit",
		"dev": "wireit",
		"prepack": "node ./scripts/prepack.js"
	},
	"types": "dist/index.d.ts",
	"dependencies": {
		"@infineon/infineon-design-system-stencil": "workspace:*",
		"tslib": "^2.3.0"
	},
	"peerDependencies": {
		"@angular/core": ">=20",
		"@angular/forms": ">=20"
	},
	"devDependencies": {
		"@analogjs/vite-plugin-angular": "^1.14.0",
		"@angular/animations": "^20.1.4",
		"@angular/common": "^20.1.4",
		"@angular/compiler": "^20.1.4",
		"@angular/compiler-cli": "^20.1.4",
		"@angular/core": "^20.1.4",
		"@angular/forms": "^20.1.4",
		"@angular/platform-browser": "^20.1.4",
		"@angular/platform-browser-dynamic": "^20.1.4",
		"@angular/router": "^20.1.4",
		"@types/node": "^25.3.0",
		"fs-extra": "^10.1.0",
		"jsdom": "^28.1.0",
		"ng-packagr": "^20.1.0",
		"rxjs": "~7.8.0",
		"tslib": "^2.3.0",
		"typescript": "5.9.3",
		"zone.js": "~0.15.0"
	},
	"publishConfig": {
		"directory": "dist"
	},
	"exports": {
		"./styles.css": "./src/styles.css"
	},
	"wireit": {
		"prebuild": {
			"command": "cpy \"../components/build-wrapper/angular/lib/stencil-generated/**\" src/lib/stencil-generated --parents && cpy \"../components/build-wrapper/angular-standalone/src/lib/stencil-generated/**\" standalone/src/lib/stencil-generated --parents",
			"dependencies": [
				"../components:build"
			],
			"files": [
				"../components/build-wrapper/angular/lib/stencil-generated/**",
				"../components/build-wrapper/angular-standalone/src/lib/stencil-generated/**"
			],
			"output": [
				"src/lib/stencil-generated/**",
				"standalone/src/lib/stencil-generated/**"
			]
		},
		"build": {
			"command": "ng-packagr -c tsconfig.json",
			"dependencies": [
				"prebuild"
			],
			"files": [
				"src/**",
				"standalone/**",
				"ng-package.json",
				"tsconfig.json",
				"package.json"
			],
			"output": [
				"dist/**"
			]
		},
		"dev": {
			"command": "ng-packagr -c tsconfig.json -w",
			"service": {
				"readyWhen": {
					"lineMatches": "Watching for file changes"
				}
			},
			"dependencies": [
				{
					"script": "../components:dev:angular",
					"cascade": false
				}
			]
		}
	}
}
