{
	"name": "@infineon/infineon-design-system-vue",
	"version": "39.27.0",
	"description": "Vue wrapper for Infineon Design System Web Components",
	"keywords": [
		"infineon",
		"design-system",
		"vue",
		"web-components",
		"ui-components"
	],
	"homepage": "https://infineon.github.io/infineon-design-system-stencil/",
	"bugs": {
		"url": "https://github.com/Infineon/infineon-design-system-stencil/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Infineon/infineon-design-system-stencil.git",
		"directory": "packages/wrapper-vue"
	},
	"author": "Infineon Technologies AG",
	"contributors": [
		"Fabian Pfaff <fabian.pfaff@infineon.com>"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "wireit",
		"tsc": "tsc -p . --outDir ./dist",
		"dev": "wireit"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"dependencies": {
		"@infineon/infineon-design-system-stencil": "workspace:*",
		"@stencil/vue-output-target": "^0.11.8"
	},
	"devDependencies": {
		"typescript": "5.9.3",
		"vue": "^3.5.28"
	},
	"wireit": {
		"prebuild": {
			"command": "cpy \"../components/build-wrapper/vue/lib/stencil-generated/**\" lib/stencil-generated --parents",
			"dependencies": [
				"../components:build"
			],
			"files": [
				"../components/build-wrapper/vue/lib/stencil-generated/**"
			],
			"output": [
				"lib/stencil-generated/**"
			]
		},
		"build": {
			"command": "tsc -p .",
			"dependencies": [
				"prebuild"
			],
			"files": [
				"lib/**",
				"tsconfig.json",
				"package.json"
			],
			"output": [
				"dist/**"
			]
		},
		"dev": {
			"command": "tsc -p . --watch --preserveWatchOutput --outDir ./dist",
			"service": {
				"readyWhen": {
					"lineMatches": "Watching for file changes"
				}
			},
			"dependencies": [
				{
					"script": "../components:dev:vue",
					"cascade": false
				}
			]
		}
	}
}
