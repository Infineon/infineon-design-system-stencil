{
  "name": "@infineon/infineon-design-system-mcp",
  "version": "39.8.1",
  "type": "module",
  "description": "MCP server for the Infineon Design System (DDS)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dds-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run extract-components && pnpm run bundle && pnpm run copy-assets",
    "bundle": "node ./scripts/bundle.mjs",
    "extract-components": "node ./scripts/extract-components.mjs",
    "copy-assets": "node ./scripts/copy-assets.mjs",
    "dev": "node --enable-source-maps ./dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "jsdom": "^25.0.1",
    "@lit-labs/ssr": "^3.2.2"
  },
  "devDependencies": {
    "@infineon/dds-tooling": "workspace:*",
    "@types/node": "^20.12.7",
    "esbuild": "^0.27.4",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
