{
  "name": "@infineon/infineon-design-system-mcp",
  "version": "39.20.2",
  "type": "module",
  "description": "MCP server for the Infineon Design System (DDS)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dds-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "wireit",
    "extract-components": "wireit",
    "bundle": "wireit",
    "copy-assets": "wireit",
    "dev": "node --enable-source-maps ./dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector ./dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "jsdom": "^25.0.1",
    "@lit-labs/ssr": "^3.2.2"
  },
  "devDependencies": {
    "@infineon/dds-tooling": "workspace:*",
    "@types/node": "^20.12.7",
    "esbuild": "^0.27.4",
    "typescript": "^5.4.5"
  },
  "wireit": {
    "extract-components": {
      "command": "node ./scripts/extract-components.mjs",
      "dependencies": [
        "../dds-tooling:build",
        "../components:build"
      ],
      "files": [
        "scripts/extract-components.mjs",
        "../components/src/storybook/stories/**"
      ],
      "output": [
        "assets/examples/**"
      ]
    },
    "bundle": {
      "command": "node ./scripts/bundle.mjs",
      "dependencies": [
        "extract-components"
      ],
      "files": [
        "src/**",
        "scripts/bundle.mjs",
        "tsconfig.json",
        "package.json"
      ],
      "output": [
        "dist/index.js",
        "dist/index.js.map"
      ]
    },
    "copy-assets": {
      "command": "node ./scripts/copy-assets.mjs",
      "dependencies": [
        "bundle",
        "../components:build"
      ],
      "files": [
        "assets/**",
        "scripts/copy-assets.mjs"
      ],
      "output": [
        "dist/assets/**"
      ]
    },
    "build": {
      "dependencies": [
        "copy-assets"
      ]
    }
  },
  "license": "MIT"
}
